# Gloas Builder-API multiplex test — per-participant buildoor schema.
# Run with:
#   kurtosis run github.com/ethereum-package@feat-per-participant-buildoor \
#     --args-file ~/epbs_builder_multiplex.yaml
#
# Two buildoors are wired to participant 1 (lodestar), which is the buildoor
# backend because prysm can't emit payload_attributes SSE post-gloas. The prysm
# VC signs a per-relay request auth for each buildoor URL in `relays` and ships
# them to its BN; the BN dials a client per signed builder_url and queries both
# builders in parallel, then proposes the best valid bid and reveals the block
# back to the winning builder.
#
# WATCH / report to Barnabas:
#  1. Service names confirmed: buildoor-lodestar-nethermind-1-{1,2} (matches relays).
#  2. Per-instance flags: --builder-api-require-auth + --builder-api-url must be
#     settable per instance (currently extra_args is global). Auth is off here.
#  3. Equal bids: both buildoors share buildoor_params (same subsidy), so this
#     confirms fan-out + valid-winner selection + reveal routing, NOT "picks the
#     higher bid". For that, need per-instance subsidy flags.
#  4. Prysm images below MUST be built from the gloas-builder-api-impl branch.

participants:
  # participant 1: lodestar — buildoor backend (emits payload_attributes SSE)
  - el_type: nethermind
    el_image: ethpandaops/nethermind:glamsterdam-devnet-5
    cl_type: lodestar
    cl_image: ethpandaops/lodestar:glamsterdam-devnet-5
    cl_extra_params: [--emitPayloadAttributes]
    vc_type: lodestar
    vc_image: ethpandaops/lodestar:glamsterdam-devnet-5
    cl_log_level: "debug"
    validator_count: 16
  # participant 2: prysm under test
  - el_type: nethermind
    el_image: ethpandaops/nethermind:glamsterdam-devnet-5
    cl_type: prysm
    cl_image: gcr.io/offchainlabs/prysm/beacon-chain:latest
    vc_type: prysm
    vc_image: gcr.io/offchainlabs/prysm/validator:latest
    cl_log_level: "debug"
    count: 2
    validator_count: 128
    vc_extra_params: [--proposer-settings-file=/proposer/proposer-settings.json]
    vc_extra_mounts:
      /proposer: proposer-settings.json

network_params:
  gloas_fork_epoch: 1
  preset: mainnet
  min_validator_withdrawability_delay: 1
  shard_committee_period: 1
  churn_limit_quotient: 16
  seconds_per_slot: 6
  gas_limit: 150000000

# Two builders on participant 1 (lodestar). Running Barnabas's OFFICIAL #1432
# (commit 5ff8db70) which sets --builder-api-url per instance, plus the default
# buildoor:main image (devnet-5 + --extra-data, both merged upstream). Both
# buildoors validate their own auths and bid; prysm picks the highest. Subsidies
# are equal upstream, so the two bids tie (best-of-N "higher wins" was shown
# separately via a differentiated-subsidy launcher patch).
buildoor_params:
  image: ethpandaops/buildoor:main
  builder_api: true
  epbs_builder: false
  lifecycle: true
  instances:
    - participant: 1
      count: 2
  extra_args:
    # require-auth ON: the official launcher gives each instance its own
    # --builder-api-url, so per-builder auth validation works for all buildoors.
    - --builder-api-require-auth

extra_files:
  proposer-settings.json: |
    {
      "default_config": {
        "fee_recipient": "0x8943545177806ED17B9F23F0a21ee5948eCaa776",
        "builder": {
          "enabled": true,
          "relays": [
            "http://buildoor-lodestar-nethermind-1-1:8080",
            "http://buildoor-lodestar-nethermind-1-2:8080"
          ],
          "max_execution_payment": "18446744073709551615"
        }
      }
    }

additional_services: [buildoor, dora, spamoor, assertoor]

spamoor_params:
  image: ethpandaops/spamoor:master
  spammers:
    - scenario: eoatx
      config: {throughput: 2}

dora_params:
  image: ethpandaops/dora:latest

assertoor_params:
  run_stability_check: false
  run_block_proposal_check: false
  tests:
    - { file: "https://raw.githubusercontent.com/ethpandaops/assertoor/refs/heads/master/playbooks/dev/fund-wallet.yaml", config: { targetAddress: "0x332E43696A505EF45b9319973785F837ce5267b9" } }
    - { file: "https://raw.githubusercontent.com/ethpandaops/assertoor/refs/heads/gloas-support/playbooks/gloas-dev/builder-lifecycle.yaml" }
