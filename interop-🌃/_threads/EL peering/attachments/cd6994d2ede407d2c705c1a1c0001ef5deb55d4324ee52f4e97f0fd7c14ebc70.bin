func TestAnswerGetReceiptsQuery70_PreservesSnapshotEmptyReceiptsWhenRawdbHeaderMissing(t *testing.T) {
	ctx := context.Background()
	db := temporaltest.NewTestDB(t, datadir.New(t.TempDir()))
	tx, err := db.BeginTemporalRo(ctx)
	if err != nil {
		t.Fatal(err)
	}
	defer tx.Rollback()

	header := &types.Header{ReceiptHash: empty.RootHash}
	header.Number.SetUint64(14091)
	block := types.NewBlock(header, nil, nil, nil, nil)
	hash := block.Hash()
	reader := snapshotOnlyReceiptBlockReader{block: block, number: 14091}

	result, lastBlockIncomplete, err := AnswerGetReceiptsQuery(ctx, &chain.Config{}, nilReceiptsGetter{}, reader, tx, GetReceiptsPacket{hash}, nil, eth70Opts(0))
	if err != nil {
		t.Fatal(err)
	}
	if lastBlockIncomplete {
		t.Fatal("empty receipts block should be complete")
	}
	if len(result) != 1 {
		t.Fatalf("expected empty receipts list to preserve request position, got %d entries", len(result))
	}
}
